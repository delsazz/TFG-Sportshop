# Base de datos
DB_NAME=uniformes
DB_USER=uniformes
DB_PASS=uniformes_pass

# JWT
JWT_SECRET=cambia-este-secreto-en-produccion
JWT_EXPIRATION=86400000

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:5173/pagos/exito?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:5173/pagos/cancelado

# Email de notificaciones
# Ejemplo Gmail:
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=tu_correo@gmail.com
# MAIL_PASSWORD=tu_password_de_aplicacion
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_SMTP_STARTTLS_REQUIRED=true
NOTIFICATIONS_EMAIL_ENABLED=true
NOTIFICATIONS_EMAIL_FROM=
REGISTRATION_EMAIL_ENABLED=true
REGISTRATION_EMAIL_FROM=
PASSWORD_RESET_EMAIL_ENABLED=true
PASSWORD_RESET_EMAIL_FROM=
APP_FRONTEND_URL=http://localhost:5173
