{
  "uid": "campusfp-services",
  "title": "CampusFP - Estado de servicios",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Endpoints HTTP disponibles",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 5, "w": 8, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(probe_success{job=\"blackbox-http\"})",
          "legendFormat": "disponibles",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "green", "value": 3}
            ]
          }
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Targets Prometheus activos",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 5, "w": 8, "x": 8, "y": 0},
      "targets": [
        {
          "expr": "sum(up)",
          "legendFormat": "up",
          "refId": "A"
        }
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Contenedores vistos",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 5, "w": 8, "x": 16, "y": 0},
      "targets": [
        {
          "expr": "count(container_last_seen{name=~\".+\"})",
          "legendFormat": "contenedores",
          "refId": "A"
        }
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Disponibilidad HTTP",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "targets": [
        {
          "expr": "probe_success{job=\"blackbox-http\"}",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "CPU por contenedor",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "targets": [
        {
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\".+\"}[5m]))",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Logs centralizados",
      "datasource": {"type": "loki", "uid": "Loki"},
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 13},
      "targets": [
        {
          "expr": "{compose_project=~\".+\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showLabels": true,
        "showTime": true,
        "wrapLogMessage": true
      }
    }
  ]
}
